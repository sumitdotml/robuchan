{
  "permissions": {
    "allow": [
      "WebFetch(domain:docs.mistral.ai)",
      "WebFetch(domain:mistral.ai)",
      "mcp__plugin_context7_context7__query-docs",
      "WebFetch(domain:www.notion.so)",
      "WebFetch(domain:wandb.ai)",
      "WebFetch(domain:worldwide-hackathon.mistral.ai)",
      "mcp__plugin_context7_context7__resolve-library-id",
      "WebFetch(domain:docs.wandb.ai)",
      "WebFetch(domain:machinelearning.apple.com)",
      "Bash(uv sync)",
      "Bash(uv run python -c \"import data.audit_dataset; import data.prepare; print\\(''Imports OK''\\)\")",
      "Bash(uv run python data/prepare.py ingest)",
      "Bash(osascript -e 'tell application \"\"Terminal\"\" to do script \"\"uv run python data/prepare.py ingest\"\"')",
      "WebFetch(domain:api.github.com)",
      "Bash(npx tsc --noEmit)",
      "WebFetch(domain:archive.org)",
      "Bash(tmux capture-pane:*)"
    ]
  },
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "$CLAUDE_PROJECT_DIR/.claude/hooks/block-dangerous-git.sh"
          },
          {
            "type": "command",
            "command": "$CLAUDE_PROJECT_DIR/.claude/hooks/block-pip.sh"
          }
        ]
      }
    ]
  }
}
