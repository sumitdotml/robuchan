{
  "permissions": {
    "allow": [
      "WebFetch(domain:docs.mistral.ai)",
      "WebFetch(domain:mistral.ai)"
    ]
  },
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "$CLAUDE_PROJECT_DIR/.claude/hooks/block-dangerous-git.sh"
          },
          {
            "type": "command",
            "command": "$CLAUDE_PROJECT_DIR/.claude/hooks/block-pip.sh"
          }
        ]
      }
    ]
  }
}
